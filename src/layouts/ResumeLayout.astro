---
import "../styles/global.css";

interface Props {
  frontmatter: {
    name: string;
    email: string;
    phone: string;
    website: string;
  };
}

const { name, email, phone, website } = Astro.props.frontmatter;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{name} — Resume</title>
  </head>
  <body class="print:bg-white print:text-black">
    <div class="mx-auto max-w-7xl px-4 py-6">
      <header class="mb-6">
        <h1 class="text-3xl font-bold text-gray-900 mb-2 leading-none">
          {name}
        </h1>
        <p class="text-gray-500 text-lg mb-3">
          <a
            href={`mailto:${email}`}
            class="cursor-pointer text-indigo-600 visited:text-indigo-600 underline underline-offset-2 hover:text-indigo-800 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 focus-visible:rounded-sm"
            >{email}</a
          > ·
          <a
            href={`tel:${phone}`}
            class="cursor-pointer text-indigo-600 visited:text-indigo-600 underline underline-offset-2 hover:text-indigo-800 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 focus-visible:rounded-sm"
            >{phone}</a
          > ·
          <a
            href={website}
            class="cursor-pointer text-indigo-600 visited:text-indigo-600 underline underline-offset-2 hover:text-indigo-800 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 focus-visible:rounded-sm"
            >{website}</a
          >
        </p>
        <button
          class="text-sm px-3 py-1 bg-gray-900 text-white border-none rounded cursor-pointer hover:bg-gray-600 print:hidden"
          onclick="window.print()"
        >
          Download PDF
        </button>
      </header>
      <main
        class="prose max-w-none prose-h2:text-sm prose-h2:font-bold prose-h2:text-gray-500 prose-h2:uppercase prose-h2:tracking-wide prose-h2:border-b prose-h2:border-gray-300 prose-h2:pb-1 prose-h2:mt-6 prose-h2:mb-3 prose-h3:text-lg prose-h3:font-semibold prose-h3:text-gray-900 prose-h3:mt-4 prose-h3:mb-1 prose-h3:print:break-after-avoid prose-em:italic prose-em:text-gray-500 prose-ul:list-disc prose-ul:my-2 prose-ul:mb-3 prose-ul:pl-5 prose-li:mb-1 prose-li:leading-relaxed prose-p:my-2 prose-p:leading-relaxed prose-a:cursor-pointer prose-a:text-indigo-600 visited:prose-a:text-indigo-600 prose-a:underline prose-a:underline-offset-1 hover:prose-a:text-indigo-900 focus-visible:prose-a:outline-2 focus-visible:prose-a:outline-offset-2 focus-visible:prose-a:outline-indigo-600 focus-visible:prose-a:rounded-sm print:prose-a:no-underline"
      >
        <slot />
      </main>
    </div>
  </body>
</html>
