---
import "../styles/global.css";

interface Props {
  frontmatter: {
    name: string;
    email: string;
    phone: string;
    website: string;
  };
}

const { name, email, phone, website } = Astro.props.frontmatter;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{name} — Resume</title>
  </head>
  <body>
    <div class="resume-container">
      <header class="resume-header">
        <h1 class="resume-name">{name}</h1>
        <p class="resume-contact">
          <a href={`mailto:${email}`}>{email}</a> ·
          <a href={`tel:${phone}`}>{phone}</a> ·
          <a href={website}>{website}</a>
        </p>
        <button class="resume-download-btn" onclick="window.print()">
          Download PDF
        </button>
      </header>
      <main class="resume-body">
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  .resume-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.25rem;
  }

  .resume-header {
    margin-bottom: 2rem;
  }

  .resume-name {
    font-size: 2.5rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 0.5rem;
    line-height: 1.1;
  }

  .resume-contact {
    color: #555;
    font-size: 1.125rem;
    margin: 0 0 1rem;
  }

  .resume-contact a {
    color: #4338ca;
    text-decoration: underline;
    text-underline-offset: 0.25rem;
  }

  .resume-contact a:hover {
    color: #312e81;
  }

  .resume-contact a:focus-visible {
    outline: 2px solid #4338ca;
    outline-offset: 2px;
    border-radius: 2px;
  }

  .resume-download-btn {
    font-size: 0.875rem;
    padding: 0.25rem 1rem;
    background: #1a1a1a;
    color: #f9f9f9;
    border: none;
    border-radius: 4px;
    cursor: pointer;
  }

  .resume-download-btn:hover {
    background: #555;
  }

  .resume-body :global(h2) {
    font-size: 0.875rem;
    font-weight: 700;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.075em;
    border-bottom: 1px solid #e0e0e0;
    padding-bottom: 0.25rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .resume-body :global(h3) {
    font-size: 1.125rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-top: 1.25rem;
    margin-bottom: 0.25rem;
  }

  .resume-body :global(em) {
    font-style: italic;
    color: #555;
  }

  .resume-body :global(ul) {
    margin: 0.5rem 0 1rem;
    padding-left: 1.5rem;
  }

  .resume-body :global(li) {
    margin-bottom: 0.25rem;
    line-height: 1.7;
  }

  .resume-body :global(p) {
    margin: 0.5rem 0;
    line-height: 1.7;
  }

  .resume-body :global(a) {
    color: #4338ca;
    text-decoration: underline;
    text-underline-offset: 0.25rem;
  }

  .resume-body :global(a:hover) {
    color: #312e81;
  }

  .resume-body :global(a:focus-visible) {
    outline: 2px solid #4338ca;
    outline-offset: 2px;
    border-radius: 2px;
  }

  @media print {
    html,
    body {
      background: white;
      color: black;
    }

    .resume-download-btn {
      display: none;
    }

    h3 {
      break-after: avoid;
    }

    * {
      box-shadow: none !important;
    }

    a[href]::after {
      content: none;
    }
  }
</style>
