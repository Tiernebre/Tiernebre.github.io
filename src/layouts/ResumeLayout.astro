---
import "../styles/global.css";

interface Props {
  frontmatter: {
    name: string;
    email: string;
    phone: string;
    website: string;
  };
}

const { name, email, phone, website } = Astro.props.frontmatter;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{name} — Resume</title>
  </head>
  <body>
    <div class="resume-container">
      <header class="resume-header">
        <h1 class="resume-name">{name}</h1>
        <p class="resume-contact">{email} · {phone} · {website}</p>
        <div class="resume-download-wrapper">
          <button class="resume-download-btn" onclick="window.print()">
            Download PDF
          </button>
          <span class="resume-download-hint"
            >Print to PDF in your browser's print dialog</span
          >
        </div>
      </header>
      <main class="resume-body">
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  html,
  body {
    color: var(--gray-9);
  }

  .resume-container {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--size-6) var(--size-4);
  }

  .resume-header {
    margin-bottom: var(--size-6);
  }

  .resume-name {
    font-size: var(--font-size-6);
    font-weight: var(--font-weight-7);
    color: var(--gray-9);
    margin: 0 0 var(--size-2);
    line-height: var(--font-lineheight-1);
  }

  .resume-contact {
    color: var(--gray-6);
    font-size: var(--font-size-2);
    margin: 0 0 var(--size-3);
  }

  .resume-download-wrapper {
    display: flex;
    align-items: center;
    gap: var(--size-3);
  }

  .resume-download-btn {
    font-size: var(--font-size-1);
    padding: var(--size-1) var(--size-3);
    background: var(--gray-9);
    color: #fff;
    border: none;
    border-radius: var(--radius-2);
    cursor: pointer;
  }

  .resume-download-btn:hover {
    background: var(--gray-7);
  }

  .resume-download-hint {
    font-size: var(--font-size-0);
    color: var(--gray-6);
  }

  .resume-body :global(h2) {
    font-size: var(--font-size-1);
    font-weight: var(--font-weight-7);
    color: var(--gray-7);
    text-transform: uppercase;
    letter-spacing: var(--font-letterspacing-3);
    border-bottom: 1px solid var(--gray-3);
    padding-bottom: var(--size-1);
    margin-top: var(--size-6);
    margin-bottom: var(--size-3);
  }

  .resume-body :global(h3) {
    font-size: var(--font-size-2);
    font-weight: var(--font-weight-6);
    color: var(--gray-9);
    margin-top: var(--size-4);
    margin-bottom: var(--size-1);
  }

  .resume-body :global(em) {
    font-style: italic;
    color: var(--gray-6);
  }

  .resume-body :global(ul) {
    margin: var(--size-2) 0 var(--size-3);
    padding-left: var(--size-5);
  }

  .resume-body :global(li) {
    margin-bottom: var(--size-1);
    line-height: var(--font-lineheight-3);
  }

  .resume-body :global(p) {
    margin: var(--size-2) 0;
    line-height: var(--font-lineheight-3);
  }

  .resume-body :global(a) {
    color: var(--gray-9);
  }

  @media print {
    html,
    body {
      background: white;
      color: black;
    }

    .resume-download-btn {
      display: none;
    }

    h3 {
      break-after: avoid;
    }

    * {
      box-shadow: none !important;
    }

    a[href]::after {
      content: none;
    }
  }
</style>
