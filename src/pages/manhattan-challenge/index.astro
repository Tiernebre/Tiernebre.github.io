---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ManhattanMap from "../../components/ManhattanMap.astro";
import { getWalkGeoJsonFeatures } from "../../lib/gpx";

const entries = await getCollection("manhattan-challenge");
const features = getWalkGeoJsonFeatures();

const sorted_by_date = [...entries].sort(
  (a, b) => a.data.date.getTime() - b.data.date.getTime(),
);

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
---

<Layout>
  <main class="mx-auto max-w-7xl px-6 pt-8 pb-16 text-gray-900">
    <header class="mb-8">
      <h1 class="text-4xl font-bold mb-2">Manhattan Challenge</h1>
      <p class="text-base text-gray-500">
        Walking every block of Manhattan — tracking progress one walk at a time.
      </p>
    </header>

    <section class="mb-10">
      <h2 class="text-xl font-semibold mb-4 text-gray-500">Walk Map</h2>
      <div
        class="w-full h-[790px] rounded-lg overflow-hidden border border-gray-200"
      >
        <ManhattanMap features={features} />
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-semibold mb-4 text-gray-500">Walks</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr>
              <th
                class="text-left text-xs uppercase tracking-wide text-gray-500 font-semibold px-3 py-2 border-b-2 border-gray-200"
                >Date</th
              >
              <th
                class="text-left text-xs uppercase tracking-wide text-gray-500 font-semibold px-3 py-2 border-b-2 border-gray-200"
                >Title</th
              >
              <th
                class="text-left text-xs uppercase tracking-wide text-gray-500 font-semibold px-3 py-2 border-b-2 border-gray-200"
                >Distance</th
              >
              <th
                class="text-left text-xs uppercase tracking-wide text-gray-500 font-semibold px-3 py-2 border-b-2 border-gray-200"
                >Duration</th
              >
            </tr>
          </thead>
          <tbody>
            {
              sorted_by_date.map((entry) => {
                const hours = Math.floor(entry.data.duration_minutes / 60);
                const minutes = entry.data.duration_minutes % 60;
                const duration =
                  hours > 0 ? `${hours}h ${minutes}m` : `${minutes}m`;
                return (
                  <tr class="hover:bg-gray-50">
                    <td class="px-3 py-2.5 border-b border-gray-100 whitespace-nowrap">
                      {formatDate(entry.data.date)}
                    </td>
                    <td class="px-3 py-2.5 border-b border-gray-100">
                      <a
                        href={`/manhattan-challenge/walks/${entry.data.slug}`}
                        class="text-primary no-underline font-semibold hover:underline"
                      >
                        {entry.data.title}
                      </a>
                    </td>
                    <td class="px-3 py-2.5 border-b border-gray-100 whitespace-nowrap">
                      {entry.data.distance_miles.toFixed(1)} mi
                    </td>
                    <td class="px-3 py-2.5 border-b border-gray-100 whitespace-nowrap">
                      {duration}
                    </td>
                  </tr>
                );
              })
            }
          </tbody>
        </table>
      </div>
    </section>
  </main>
</Layout>
