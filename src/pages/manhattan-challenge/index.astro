---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ManhattanMap from "../../components/ManhattanMap.astro";
import { getWalkGeoJsonFeatures } from "../../lib/gpx";

const CHALLENGE_GOAL_MILES = 1300;

const entries = await getCollection("manhattan-challenge");
const features = getWalkGeoJsonFeatures();

// Compute stats
const total_walks = entries.length;

const total_distance_raw = entries.reduce(
  (sum, e) => sum + e.data.distance_miles,
  0,
);
const total_distance = total_distance_raw.toFixed(1);

const total_duration_minutes = entries.reduce(
  (sum, e) => sum + e.data.duration_minutes,
  0,
);
const total_time_hours = Math.floor(total_duration_minutes / 60);
const total_time_minutes = total_duration_minutes % 60;
const total_time = `${total_time_hours}h ${total_time_minutes}m`;

const progress_pct = (
  (total_distance_raw / CHALLENGE_GOAL_MILES) *
  100
).toFixed(1);

const sorted_by_date = [...entries].sort(
  (a, b) => a.data.date.getTime() - b.data.date.getTime(),
);
const earliest = sorted_by_date[0];
const most_recent = sorted_by_date[sorted_by_date.length - 1];

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });

const project_span =
  entries.length > 0
    ? `${formatDate(earliest.data.date)} – ${formatDate(most_recent.data.date)}`
    : "N/A";

const most_recent_walk = most_recent;

const longest_walk_entry = entries.reduce((max, e) =>
  e.data.distance_miles > max.data.distance_miles ? e : max,
);
const longest_walk = `${longest_walk_entry.data.distance_miles.toFixed(1)} mi — ${longest_walk_entry.data.title}`;

const avg_distance =
  entries.length > 0 ? (total_distance_raw / entries.length).toFixed(1) : "0.0";

const all_neighborhoods = entries.flatMap((e) => e.data.neighborhoods);
const neighborhoods_visited = new Set(all_neighborhoods).size;
---

<Layout>
  <main>
    <header class="page-header">
      <h1>Manhattan Challenge</h1>
      <p class="subtitle">
        Walking every block of Manhattan — tracking progress one walk at a time.
      </p>
    </header>

    <section class="progress-section">
      <div class="progress-label">
        <span class="progress-pct">{progress_pct}% complete</span>
        <span class="progress-miles"
          >{total_distance} / {CHALLENGE_GOAL_MILES} mi</span
        >
      </div>
      <div class="progress-bar-track">
        <div
          class="progress-bar-fill"
          style={`width: ${Math.min(Number(progress_pct), 100)}%`}
        >
        </div>
      </div>
    </section>

    <section class="stats-section">
      <h2>Stats</h2>
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-value">{total_distance} mi</span>
          <span class="stat-label">Total Distance</span>
        </div>
        <div class="stat-card">
          <span class="stat-value">{total_time}</span>
          <span class="stat-label">Total Time</span>
        </div>
        <div class="stat-card">
          <span class="stat-value">{total_walks}</span>
          <span class="stat-label">Total Walks</span>
        </div>
        <div class="stat-card">
          <span class="stat-value">{project_span}</span>
          <span class="stat-label">Project Span</span>
        </div>
        <div class="stat-card">
          <span class="stat-value">{longest_walk}</span>
          <span class="stat-label">Longest Walk</span>
        </div>
        <div class="stat-card">
          <span class="stat-value">{avg_distance} mi</span>
          <span class="stat-label">Avg Distance</span>
        </div>
        <div class="stat-card">
          <span class="stat-value">{neighborhoods_visited}</span>
          <span class="stat-label">Neighborhoods Visited</span>
        </div>
        <div class="stat-card">
          <span class="stat-value">
            {most_recent_walk ? formatDate(most_recent_walk.data.date) : "N/A"}
          </span>
          <span class="stat-label">Most Recent Walk</span>
        </div>
      </div>
    </section>

    <section class="walks-section">
      <h2>Walks</h2>
      <div class="table-wrapper">
        <table class="walks-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Title</th>
              <th>Distance</th>
              <th>Duration</th>
            </tr>
          </thead>
          <tbody>
            {
              sorted_by_date.map((entry) => {
                const hours = Math.floor(entry.data.duration_minutes / 60);
                const minutes = entry.data.duration_minutes % 60;
                const duration =
                  hours > 0 ? `${hours}h ${minutes}m` : `${minutes}m`;
                return (
                  <tr>
                    <td>{formatDate(entry.data.date)}</td>
                    <td>
                      <a href={`/manhattan-challenge/walks/${entry.data.slug}`}>
                        {entry.data.title}
                      </a>
                    </td>
                    <td>{entry.data.distance_miles.toFixed(1)} mi</td>
                    <td>{duration}</td>
                  </tr>
                );
              })
            }
          </tbody>
        </table>
      </div>
    </section>

    <section class="map-section">
      <h2>Walk Map</h2>
      <div class="map-container">
        <ManhattanMap features={features} />
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
    font-family: var(--font-sans);
    color: var(--text-1);
  }

  .page-header {
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 2.25rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }

  h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 1rem;
    color: var(--text-2);
  }

  .subtitle {
    font-size: 1rem;
    color: var(--text-2);
    margin: 0;
  }

  /* Progress */
  .progress-section {
    margin-bottom: 2.5rem;
  }

  .progress-label {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }

  .progress-pct {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--red-7);
  }

  .progress-miles {
    font-size: 0.875rem;
    color: var(--text-2);
  }

  .progress-bar-track {
    width: 100%;
    height: 14px;
    background: var(--surface-3);
    border-radius: 999px;
    overflow: hidden;
  }

  .progress-bar-fill {
    height: 100%;
    background: var(--red-7);
    border-radius: 999px;
    transition: width 0.4s ease;
    min-width: 2px;
  }

  /* Stats */
  .stats-section {
    margin-bottom: 2.5rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
  }

  .stat-card {
    background: var(--surface-1);
    border: 1px solid var(--surface-4);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-value {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-1);
    line-height: 1.3;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-2);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 500;
  }

  /* Walks table */
  .walks-section {
    margin-bottom: 2.5rem;
  }

  .table-wrapper {
    overflow-x: auto;
  }

  .walks-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .walks-table th {
    text-align: left;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-2);
    font-weight: 600;
    padding: 0.5rem 0.75rem;
    border-bottom: 2px solid var(--surface-4);
  }

  .walks-table td {
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--surface-3);
    white-space: nowrap;
  }

  .walks-table td:nth-child(2) {
    white-space: normal;
  }

  .walks-table tbody tr:hover {
    background: var(--surface-1);
  }

  .walks-table a {
    color: var(--red-7);
    text-decoration: none;
    font-weight: 600;
  }

  .walks-table a:hover {
    text-decoration: underline;
  }

  /* Map */
  .map-section {
    margin-bottom: 2rem;
  }

  .map-container {
    width: 100%;
    height: 560px;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--surface-4);
  }
</style>
