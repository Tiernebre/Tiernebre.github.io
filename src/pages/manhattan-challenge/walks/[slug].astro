---
import { getCollection, render } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import ManhattanMap from "../../../components/ManhattanMap.astro";
import type { GeoJsonFeature } from "../../../components/ManhattanMap.astro";
import { getWalkGeoJsonFeature } from "../../../lib/gpx";

export async function getStaticPaths() {
  const walks = await getCollection("manhattan-challenge");
  const sorted = [...walks].sort(
    (a, b) => a.data.date.getTime() - b.data.date.getTime(),
  );

  return sorted.map((entry, index) => ({
    params: { slug: entry.data.slug },
    props: {
      entry,
      prev: index > 0 ? sorted[index - 1] : null,
      next: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

const formattedDate = entry.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});

const hours = Math.floor(entry.data.duration_minutes / 60);
const minutes = entry.data.duration_minutes % 60;
const durationFormatted = hours > 0 ? `${hours}h ${minutes}m` : `${minutes}m`;

const neighborhoodList =
  entry.data.neighborhoods.length > 0
    ? entry.data.neighborhoods.join(", ")
    : "None listed";

const gpxFeature = getWalkGeoJsonFeature(entry.data.slug);
const features: GeoJsonFeature[] = gpxFeature ? [gpxFeature] : [];
---

<Layout>
  <main class="mx-auto max-w-7xl px-4 py-8">
    <header class="mb-6">
      <a
        href="/manhattan-challenge"
        class="text-primary no-underline text-sm font-semibold hover:underline inline-flex items-center gap-1 mb-2"
      >
        &larr; All walks
      </a>
      <h1 class="text-[clamp(1.5rem,4vw,2rem)] leading-tight mb-1">
        {entry.data.title}
      </h1>
      <p class="text-gray-500 text-base">{formattedDate}</p>
    </header>

    <div class="flex gap-8 flex-wrap bg-gray-100 rounded-lg px-6 py-4 mb-6">
      <div class="flex flex-col gap-1">
        <span
          class="text-xs uppercase tracking-wider text-gray-500 font-semibold"
          >Distance</span
        >
        <span class="text-base font-semibold text-gray-900"
          >{entry.data.distance_miles.toFixed(1)} mi</span
        >
      </div>
      <div class="flex flex-col gap-1">
        <span
          class="text-xs uppercase tracking-wider text-gray-500 font-semibold"
          >Duration</span
        >
        <span class="text-base font-semibold text-gray-900"
          >{durationFormatted}</span
        >
      </div>
      <div class="flex flex-col gap-1">
        <span
          class="text-xs uppercase tracking-wider text-gray-500 font-semibold"
          >Neighborhoods</span
        >
        <span class="text-base font-semibold text-gray-900"
          >{neighborhoodList}</span
        >
      </div>
      {
        entry.data.weather && (
          <div class="flex flex-col gap-1">
            <span class="text-xs uppercase tracking-wider text-gray-500 font-semibold">
              Weather
            </span>
            <span class="text-base font-semibold text-gray-900">
              {entry.data.weather.condition}, {entry.data.weather.temp_f}°F
            </span>
          </div>
        )
      }
    </div>

    <div class="h-[400px] mb-8 rounded-lg overflow-hidden">
      <ManhattanMap features={features} fitBounds={true} interactive={false} />
    </div>

    <div class="leading-relaxed text-gray-900 mb-8 walk-body">
      <Content />
    </div>

    <nav class="flex justify-between border-t border-gray-200 pt-6 mt-4">
      {
        prev && (
          <a
            href={`/manhattan-challenge/walks/${prev.data.slug}`}
            class="text-primary no-underline font-semibold text-[0.95rem] hover:underline"
          >
            &larr; Previous walk
          </a>
        )
      }
      {
        next && (
          <a
            href={`/manhattan-challenge/walks/${next.data.slug}`}
            class="text-primary no-underline font-semibold text-[0.95rem] hover:underline ml-auto"
          >
            Next walk &rarr;
          </a>
        )
      }
    </nav>
  </main>
</Layout>
