---
export interface GeoJsonFeatureProperties {
  slug: string;
  date: string;
  title: string;
}

export interface GeoJsonFeature {
  type: "Feature";
  properties: GeoJsonFeatureProperties;
  geometry: {
    type: "LineString";
    coordinates: [number, number][];
  };
}

interface Props {
  features: GeoJsonFeature[];
  fitBounds?: boolean;
  interactive?: boolean;
}

const { features, fitBounds = false, interactive = true } = Astro.props;
const featuresJson = JSON.stringify(features);
---

<div
  id="manhattan-map"
  data-features={featuresJson}
  data-fit-bounds={fitBounds ? "true" : "false"}
  data-interactive={interactive ? "true" : "false"}
>
</div>

<script>
  import L from "leaflet";
  import "leaflet/dist/leaflet.css";

  const mapEl = document.getElementById("manhattan-map");
  if (!mapEl) throw new Error("Map element not found");

  const features = JSON.parse(mapEl.dataset.features ?? "[]");
  const shouldFitBounds = mapEl.dataset.fitBounds === "true";
  const isInteractive = mapEl.dataset.interactive !== "false";

  const map = L.map("manhattan-map");

  L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
    maxZoom: 19,
    attribution:
      '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
  }).addTo(map);

  const polylineColor = "#bf00ff";
  const allLatLngs: [number, number][] = [];

  features.forEach(function (feature) {
    if (
      !feature.geometry ||
      feature.geometry.type !== "LineString" ||
      !feature.properties
    ) {
      return;
    }

    // Leaflet expects [lat, lng]; GeoJSON uses [lng, lat]
    const latLngs: [number, number][] = feature.geometry.coordinates.map(
      function (coord) {
        return [coord[1], coord[0]];
      },
    );

    allLatLngs.push(...latLngs);

    const polyline = L.polyline(latLngs, {
      color: polylineColor,
      weight: 4,
      opacity: 0.8,
    }).addTo(map);

    const props = feature.properties;
    const formattedDate = new Date(props.date).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
      timeZone: "UTC",
    });

    if (isInteractive) {
      polyline.on("click", function (e) {
        L.popup()
          .setLatLng(e.latlng)
          .setContent(
            '<div class="manhattan-map-popup">' +
              "<p>" +
              formattedDate +
              "</p>" +
              '<a href="/manhattan-challenge/walks/' +
              props.slug +
              '">View walk details &#x2192;</a>' +
              "</div>",
          )
          .openOn(map);
      });
    }
  });

  if (shouldFitBounds && allLatLngs.length > 0) {
    map.fitBounds(allLatLngs, { padding: [20, 20] });
  } else {
    map.setView([40.7831, -73.9712], 12);
  }
</script>

<style>
  #manhattan-map {
    width: 100%;
    height: 100%;
    min-height: 400px;
  }

  #manhattan-map :global(.manhattan-map-popup p) {
    margin: 0 0 0.5rem 0;
    font-size: 0.875rem;
    color: #555;
  }

  #manhattan-map :global(.manhattan-map-popup a) {
    color: #7c3aed;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.875rem;
  }

  #manhattan-map :global(.manhattan-map-popup a:hover) {
    text-decoration: underline;
  }
</style>
